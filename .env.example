# Shelby Drop Environment Configuration
# Copy this file to .env.local and fill in your values

# ===========================================
# APTOS / SHELBY NETWORK CONFIGURATION
# ===========================================
APTOS_NETWORK=testnet
SHELBY_NETWORK=testnet

# ===========================================
# WALLET CONFIGURATION (SERVER ONLY - REQUIRED)
# ===========================================
# Server wallet that pays for storage and transaction fees
# Get this from your wallet or generate a new one
SHELBY_ACCOUNT_ADDRESS=0x50093856644bfcf8e33e3979b52f1a71f79f24a6ed7da94aa92b5b4057e0d0bb
SHELBY_ACCOUNT_PRIVATE_KEY=ed25519-priv-0xffaa7fe6f9ff89d24e4fe31a894a33f3e125844b51dd9e1cd1810466eb374720

# ===========================================
# SHELBY API CONFIGURATION (REQUIRED)
# ===========================================
# API key for higher rate limits (REQUIRED for production)
# Get your API key from: https://geomi.dev
# Format: aptoslabs_********
SHELBY_API_KEY=aptoslabs_ds6fbScR646_CriMpa4ieRZZPuNqTuqZbZAMZAWE5dck

# ===========================================
# APTOS API ENDPOINTS (REQUIRED)
# ===========================================
# Aptos node and indexer URLs for Shelby testnet
APTOS_NODE_URL=https://api.testnet.shelby.xyz/v1
APTOS_INDEXER_URL=https://api.testnet.shelby.xyz/v1/graphql

# ===========================================
# EXPLORER BASE URLS
# ===========================================
APTOS_EXPLORER_BASE=https://explorer.aptoslabs.com
SHELBY_EXPLORER_BASE=https://explorer.shelby.xyz/testnet

# ===========================================
# SHELBY SIGNING SECRET (for signed URLs)
# ===========================================
# Secret for signing file access URLs
SHELBY_SIGNING_SECRET=AG-5C7KE9J3JB8BVEVS11DYBUXZZBHIZK91H

# ===========================================
# ADDITIONAL CONFIGURATION
# ===========================================
# Shelby Gateway URLs
SHELBY_ENDPOINT=https://gateway.shelby.xyz
SHELBY_BUCKET=shelby-drop
SHELBY_ORIGIN=https://explorer.shelby.xyz

# Public URLs (safe for client)
NEXT_PUBLIC_SHELBY_NETWORK=testnet
NEXT_PUBLIC_S3_GATEWAY_ORIGIN=https://gateway.shelby.xyz
NEXT_PUBLIC_BASE_URL=https://shelby-drop.vercel.app
